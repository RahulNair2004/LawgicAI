modules = ["python-3.11"]

[nix]
channel = "stable-24_05"
packages = ["bash", "openssl", "postgresql"]

[deployment]
deploymentTarget = "autoscale"
run = ["gunicorn", "--bind", "0.0.0.0:5000", "main:app"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "repl_nix_workspace"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "gunicorn --bind 0.0.0.0:5000 --reuse-port --reload main:app"
waitForPort = 5000

[[workflows.workflow]]
name = "repl_nix_workspace"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "uv add flask-cors langchain langchain-community langchain-groq faiss-cpu pdfplumber python-dotenv ollama"

[[ports]]
localPort = 5000
externalPort = 80
